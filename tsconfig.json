{
    "include": ["./src/**/*.ts", "./src/**/*.tsx"],
    "compilerOptions": {
      "target": "esnext",
      "module": "esnext",
      "lib": ["dom", "es2017"],
      "moduleResolution": "node",
      "jsx": "react",
      "strict": true,
      "esModuleInterop": true,
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "noEmit": true,
      "skipLibCheck": true,
      "paths": {
        "@assets/*": ["/src/assets"]
      }
    }
  }